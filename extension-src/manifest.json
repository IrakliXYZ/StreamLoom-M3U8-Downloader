{
  "manifest_version": 3,
  "name": "StreamLoom: HLS/m3u8 Video Downloader",
  "version": "0.2.0",
  "description": "Find HLS (m3u8) streams on the current page and download as MP4 locally.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "StreamLoom"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "downloads",
    "offscreen",
    "scripting",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
